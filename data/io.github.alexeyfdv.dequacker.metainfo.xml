<component type="desktop-application">

  <id>io.github.alexeyfdv.dequacker</id>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Dequacker</name>
  <summary>Rubber duck debugger -gi explain your bug, solve it yourself</summary>

  <developer id="io.github.alexeyfdv">
    <name>Alexey</name>
  </developer>

  <description>
    <p>
      Dequacker is a rubber duck debugging tool. Describing a bug out loud,
      even to an inanimate object, forces you to articulate your assumptions
      and often reveals the solution before you finish typing.
    </p>
    <p>Features:</p>
    <ul>
      <li>Digital rubber duck, one piece</li>
      <li>Fully offline, no internet connection required</li>
      <li>Follows your system light/dark theme and accent colour</li>
    </ul>
  </description>

  <launchable type="desktop-id">
    io.github.alexeyfdv.dequacker.desktop
  </launchable>

  <translation type="gettext">dequacker</translation>

  <branding>
    <color type="primary" scheme_preference="light">#f5c842</color>
    <color type="primary" scheme_preference="dark">#c89a10</color>
  </branding>

  <content_rating type="oars-1.1"/>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
    <display_length compare="ge">360</display_length>
  </recommends>

  <supports>
    <control>touch</control>
    <control>keyboard</control>
    <control>pointing</control>
  </supports>

  <screenshots>
    <screenshot type="default">
      <image type="source">
        https://raw.githubusercontent.com/alexeyfdv/dequacker/v0.0.1/data/screenshots/main.png
