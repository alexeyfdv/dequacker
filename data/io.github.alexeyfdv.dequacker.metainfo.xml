  </screenshots>

  <url type="homepage">https://github.com/alexeyfdv/dequacker</url>
  <url type="bugtracker">https://github.com/alexeyfdv/dequacker/issues</url>
  <url type="vcs-browser">https://github.com/alexeyfdv/dequacker</url>

