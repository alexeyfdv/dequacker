<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2025 Alexey Fedorov -->
<component type="desktop-application">

  <!-- Must exactly match the .desktop filename and Flatpak manifest id -->
  <id>io.github.you.Dequacker</id>

  <name>Dequacker</name>
  <summary>Debug your code by talking to a rubber duck</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      Dequacker is a rubber duck debugging tool built with GTK4 and libadwaita.
      Explain your bug out loud to the duck — the act of explaining it clearly
      almost always reveals where the problem is.
    </p>
    <p>
      The duck always answers: Quack!
    </p>
  </description>

  <!-- Must match GETTEXT_PACKAGE in main.py -->
  <translation type="gettext">dequacker</translation>

  <!-- Must match the .desktop filename (without path) -->
  <launchable type="desktop-id">io.github.you.Dequacker.desktop</launchable>

  <!-- Replace 'you' with your real GitHub username -->
  <url type="homepage">https://github.com/you/dequacker</url>
  <url type="bugtracker">https://github.com/you/dequacker/issues</url>
  <url type="vcs-browser">https://github.com/you/dequacker</url>

  <!-- developer id must be reverse-DNS of your identity -->
  <developer id="io.github.you">
    <name>Alexey Fedorov</name>
  </developer>

  <!-- Branding colours shown in GNOME Software / Flathub web -->
  <branding>
    <color type="primary" scheme_preference="light">#FFD700</color>
    <color type="primary" scheme_preference="dark">#b8960c</color>
  </branding>

  <!-- OARS content rating — this app has no mature content -->
  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.0.1" date="2025-01-01">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>

  <!-- Uncomment and fill in once you have screenshots hosted on GitHub:
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/you/dequacker/main/data/screenshots/welcome.png</image>
      <caption>Welcome screen with the rubber duck</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/you/dequacker/main/data/screenshots/chat.png</image>
      <caption>Chat session with the duck</caption>
    </screenshot>
  </screenshots>
  -->

</component>
