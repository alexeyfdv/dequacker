msgid "Dequacker"
msgstr "Dequacker"

msgid "Describe your bug to the duck…"
msgstr "Opisz swój błąd kaczce…"

msgid "Send"
msgstr "Wyślij"

msgid "Quack! 🦆  Tell me about your bug."
msgstr "Kwa? 🦆  Opowiedz mi o swoim błędzie."

msgid "Quack?"
msgstr "Kwa?"

msgid "Got a bug? Consult the duck.\nExplaining the problem is half the solution. 🦆"
msgstr "Masz błąd? Skonsultuj się z kaczką.\nWyjaśnienie problemu to połowa rozwiązania. 🦆"

msgid "Consult the Duck"
msgstr "Skonsultuj się z kaczką"

msgid "Your rubber duck is listening"
msgstr "Twoja gumowa kaczka słucha"

msgid "Quack quack! 🦆"
msgstr "Kwa kwa! 🦆"

msgid "New session"
msgstr "Nowa sesja"

msgid "Main menu"
msgstr "Menu główne"

msgid "About Dequacker"
msgstr "O Dequackerze"

msgid "Quit"
msgstr "Wyjdź"

msgid "The rubber duck debugging tool.\nTalk to the duck. Quack the bug away.\nThe duck always says Quack. 🦆"
msgstr "Narzędzie do debugowania z gumową kaczką.\nRozmawiaj z kaczką. Zakwacz błąd.\nKaczka zawsze mówi Kwa. 🦆"

msgid "You"
msgstr "Ty"

msgid "Talk to the duck — it listens.\nExplaining the problem is half the solution."
msgstr "Porozmawiaj z kaczką — słucha.\nWyjaśnienie problemu to połowa rozwiązania."

msgid "Chat Mode"
msgstr "Skonsultuj się z kaczką"

msgid "Encouragement"
msgstr "Wsparcie"

msgid "Chat mode"
msgstr "Konsultacja z kaczką"

msgid "Copy"
msgstr "Kopiuj"

msgid "Quack! Tell me about your bug."
msgstr "Kwa! Opowiedz mi o swoim błędzie."

msgid "You're doing great"
msgstr "Radzisz sobie świetnie"

msgid "Everyone gets stuck sometimes"
msgstr "Każdy czasem się blokuje"

msgid "You've solved hard problems before"
msgstr "Już rozwiązywałeś trudne problemy"

msgid "Take a breath — you've got this"
msgstr "Weź oddech — dasz radę"

msgid "You're learning with every problem"
msgstr "Uczysz się z każdym problemem"

msgid "You're almost there"
msgstr "Jesteś już prawie tam"

msgid "The solution is closer than you think"
msgstr "Rozwiązanie jest bliżej niż myślisz"

msgid "Consulting the duck"
msgstr "Konsultacja z kaczką"

