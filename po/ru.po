msgid "Dequacker"
msgstr "Декрякер"

msgid "Describe your bug to the duck…"
msgstr "Опишите свою ошибку утке…"

msgid "Send"
msgstr "Отправить"

msgid "Quack! 🦆  Tell me about your bug."
msgstr "Кря! Расскажите об ошибке."

msgid "Quack?"
msgstr "Кря?"

msgid "Got a bug? Consult the duck.\nExplaining the problem is half the solution. 🦆"
msgstr "Нашли баг? Проконсультируйтесь с уткой.\nОбъяснить проблему — уже половина решения."

msgid "Consult the Duck"
msgstr "Проконсультироваться с уткой"

msgid "Your rubber duck is listening"
msgstr "Ваша резиновая утка слушает"

msgid "Quack quack! 🦆"
msgstr "Кря-кря!"

msgid "New session"
msgstr "Новая сессия"

msgid "Main menu"
msgstr "Главное меню"

msgid "About Dequacker"
msgstr "О Декрякере"

msgid "Quit"
msgstr "Выйти"

msgid "The rubber duck debugging tool.\nTalk to the duck. Quack the bug away.\nThe duck always says Quack. 🦆"
msgstr "Инструмент отладки с резиновой уткой.\nРасскажите утке. Прокрякайте баг.\nУтка всегда говорит Кря."

msgid "You"
msgstr "Вы"

msgid "Talk to the duck — it listens.\nExplaining the problem is half the solution."
msgstr "Поговорите с уткой — она слушает.\nОбъяснить проблему — уже половина решения."

msgid "Chat Mode"
msgstr "Проконсультироваться с уткой"

msgid "Encouragement"
msgstr "Поддержка"

msgid "Chat mode"
msgstr "Консультация с уткой"

msgid "Copy"
msgstr "Копировать"

msgid "Quack! Tell me about your bug."
msgstr "Кря! Расскажите об ошибке."

msgid "You're doing great"
msgstr "Всё идёт как надо"

msgid "Everyone gets stuck sometimes"
msgstr "Бывает, что решение не идёт — это нормально"

msgid "You've solved hard problems before"
msgstr "Вы уже вытаскивали себя из таких ситуаций"

msgid "Take a breath — you've got this"
msgstr "Выдохните. Вы справитесь"

msgid "You're learning with every problem"
msgstr "Каждый баг делает вас чуть опытнее"

msgid "You're almost there"
msgstr "Ещё немного — и всё сложится"

msgid "The solution is closer than you think"
msgstr "Ответ уже где-то рядом"

msgid "Consulting the duck"
msgstr "Консультация с уткой"

